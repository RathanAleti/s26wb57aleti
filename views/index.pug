extends layout

block content
  h1= title
  p Welcome to #{title}
  button(type="button", class="btn btn-primary", onclick="reduce()") Click Me

  div#use take some away

  script.
    var current = 11
    var quantity = 2
    function reduce() {
      current -= quantity
      if (current < 0) current = 0
      document.getElementById('use').innerHTML =
        'Reduced by ' + quantity + ' to ' + current + '.'
    }